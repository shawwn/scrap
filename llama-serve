#!/bin/sh
#
# Notes on the flags:

# --jinja uses the chat template baked into the GGUF, so it enters
# chat mode automatically instead of raw text completion.
#
# -c 8192 sets context length. Raise it if you need more, but it eats
# more RAM/VRAM.
#
# -ngl 99 offloads as many layers as possible to GPU. If you're on CPU
# only, drop this.
#
# -fa enables flash attention, which usually speeds things up if your
# build supports it.

# If you're on Apple Silicon with Metal, -ngl 99 still works since
# llama.cpp auto-detects Metal in the default build.

model="${1:-Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf}"
port="${2:-8000}"
ctx="${3:-8192}"
ngl="${4:-99}"
shift 4

exec llama-server \
  -m "$model" \
  --jinja \
  -c "${ctx}" \
  -ngl "${ngl}" \
  -fa on \
  --host 127.0.0.1 \
  --port $port

