#!/usr/bin/env python3
# macOS only; pyobjc ships with the system Python, else: pip install pyobjc
import objc
from Foundation import NSBundle, NSMutableArray, NSString

SF = NSBundle.bundleWithPath_('/System/Library/Frameworks/SecurityFoundation.framework')
SF.load()

objc.createOpaquePointerType("SFPWAContextRef", b"^{_SFPWAContext=}", None)
objc.loadBundleFunctions(SF, globals(), [
    ('SFPWAPolicyCopyDefault', b'@'),
    ('SFPWAContextCreateWithDefaults', b'^{_SFPWAContext=}'),
    ('SFPWAContextLoadDictionaries', b'v^{_SFPWAContext=}^{__CFArray=}I'),
    ('SFPWAPasswordSuggest', b'@^{_SFPWAContext=}^{__CFDictionary=}IIII'),
])

MEMORABLE = 0  # kSFPWAAlgorithmMemorable

def memorable(length=12, count=5, lang='en'):
    policy = SFPWAPolicyCopyDefault()
    ctx = SFPWAContextCreateWithDefaults()
    langs = NSMutableArray.array()
    langs.addObject_(NSString.stringWithString_(lang))
    SFPWAContextLoadDictionaries(ctx, langs, True)
    return list(SFPWAPasswordSuggest(ctx, policy, length, 0, count, MEMORABLE))

print(memorable())
