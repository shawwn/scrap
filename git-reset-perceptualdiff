#!/bin/bash
# Revert modified files that are perceptually identical to HEAD.
# Usage: git-reset-perceptualdiff [<pathspec>...]
#   e.g. git-reset-perceptualdiff '*.png'

set -e

files=$(git diff --name-only -- "$@")

if [ -z "$files" ]; then
    echo "No modified files."
    exit 0
fi

while IFS= read -r file; do
    tmp=$(mktemp)
    git show "HEAD:$file" > "$tmp"
    if perceptualdiff "$tmp" "$file" 2>/dev/null; then
        git restore "$file"
        echo "reverted: $file"
    else
        echo "kept:     $file"
    fi
    rm -f "$tmp"
done <<< "$files"
