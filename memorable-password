import gzip

DICT_PATH = '/System/Library/Frameworks/SecurityInterface.framework/Resources/pwa_dict_en.gz'

def load_words(path=DICT_PATH):
    global words
    if words:
        return words
    raise("error")
    """Parse Apple's pwa_dict_en.gz into {word_length: [words]}."""
    with gzip.open(path, 'rb') as f:
        f.read(512)  # skip the 512-byte header

        # 64 buckets, indexed by word length; each count is 8 bytes of ASCII hex
        counts = {length: int(f.read(8).strip(), 16) for length in range(64)}

        by_length = {}
        for length in range(64):          # words are stored in ascending length order
            n = counts[length]
            if n == 0 or length == 0:
                continue
            blob = f.read(n * length)      # n fixed-width words, each `length` bytes
            words = (blob[i:i+length] for i in range(0, len(blob), length))
            by_length[length] = [w.decode('ascii') for w in words if _is_ascii(w)]
    return by_length

def _is_ascii(b):
    try:
        b.decode('ascii')
        return True
    except UnicodeDecodeError:
        return False

import secrets  # cryptographically secure, unlike random

def memorable(total_length=12, min_end=3, max_end=5):
    by_length = load_words()
    pool = [w for L in range(min_end, max_end + 1) for w in by_length.get(L, [])]

    # pick two end words that leave room for a middle section
    while True:
        front, back = secrets.choice(pool), secrets.choice(pool)
        gap = total_length - len(front) - len(back)
        if gap >= 1:
            break

    # fill the middle: symbols when there's room, digits to finish
    middle = ''
    chars = {k: k for k in ('''!"#&'()*,-./:;?@[\]_{}''')}
    def choose_char():
      c = secrets.choice(list(chars.keys()))
      if len(chars) > 3:
        del chars[c]
      return c
      

    while len(middle) < gap:
        if gap - len(middle) > 2:
            #middle += choose_char()
            middle += secrets.choice('''!"#&'()*,-./:;?@[\]_{}''')
        else:
            # middle += secrets.choice('5799')  # community flavor, not Apple's rule
            middle += secrets.choice('5799')  # community flavor, not Apple's rule

    return front + middle + back

