import argparse

def get_parser(parser=None):
    if parser is None:
        parser = argparse.ArgumentParser(formatter_class=argparse.RawTextHelpFormatter, 
            description=memorable_password.__doc__.strip())

    parser.add_argument('-v', '--verbose',
        action="store_true",
        help="verbose output" )

    parser.add_argument('-0', '--print0',
        action="store_true",
        help="Prints \\0 after each result rather than newline" )

    parser.add_argument('--length', type=int, help="length of each password", default=12)
    parser.add_argument('--count', type=int, help="how many passwords to generate", default=5)
    return parser

