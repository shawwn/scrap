#!/usr/bin/env python3
"""imgpaste - save clipboard image to a PNG file.

Filename patterns (% expansions):
  %   full timestamp  2026-04-16-03-12-27
  %d  date only       2026-04-16
  %t  time only       03-12-27
  %%  literal %

Extension defaults to .png if omitted.
If the target file exists, _2 / _3 / ... is appended before the extension.

Usage:
  imgpaste [-f] [FILENAME]

  -f   overwrite existing file instead of auto-incrementing

Examples:
  imgpaste                   -> image-2026-04-16-03-12-27.png
  imgpaste rtml-%            -> rtml-2026-04-16-03-12-27.png  (or _2, _3 ...)
  imgpaste shot-%d           -> shot-2026-04-16.png
  imgpaste clip-%t.jpg       -> clip-03-12-27.jpg
  imgpaste -f rtml-%         -> rtml-2026-04-16-03-12-27.png  (overwrite)
"""
import sys
import os
from datetime import datetime

def expand_filename(template, now):
    date = now.strftime("%Y-%m-%d")
    time = now.strftime("%H-%M-%S")
    stamp = f"{date}-{time}"
    # Replace longest matches first to avoid %d being caught by bare %
    result = (template
              .replace("%%", "\x00")   # protect literal %%
              .replace("%d", date)
              .replace("%t", time)
              .replace("%",  stamp)
              .replace("\x00", "%"))
    # Default extension to .png
    if not os.path.splitext(result)[1]:
        result += ".png"
    return result

def unique_filename(path):
    if not os.path.exists(path):
        return path
    stem, ext = os.path.splitext(path)
    n = 2
    while True:
        candidate = f"{stem}_{n}{ext}"
        if not os.path.exists(candidate):
            return candidate
        n += 1

def main():
    try:
        from AppKit import NSPasteboard, NSPasteboardTypePNG, NSBitmapImageRep, NSImage
        from AppKit import NSPNGFileType
    except ImportError:
        print("error: PyObjC AppKit not available", file=sys.stderr)
        sys.exit(1)

    args = sys.argv[1:]
    overwrite = False
    if args and args[0] == "-f":
        overwrite = True
        args = args[1:]

    pb = NSPasteboard.generalPasteboard()

    # Try PNG directly
    data = pb.dataForType_(NSPasteboardTypePNG)

    if data is None:
        # Fall back to TIFF (macOS stores screenshots as TIFF internally)
        data = pb.dataForType_("public.tiff")
        if data is not None:
            rep = NSBitmapImageRep.imageRepWithData_(data)
            if rep is None:
                print("error: could not decode clipboard image", file=sys.stderr)
                sys.exit(1)
            data = rep.representationUsingType_properties_(NSPNGFileType, None)

    if data is None:
        print("error: no image in clipboard", file=sys.stderr)
        sys.exit(1)

    now = datetime.now()
    filename = expand_filename(args[0] if args else "image-%", now)
    if not overwrite:
        filename = unique_filename(filename)

    with open(filename, "wb") as f:
        f.write(bytes(data))

    print(filename)

if __name__ == "__main__":
    main()
